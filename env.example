# انسخ إلى `.env` في جذر المشروع (الملف مُستثنى من git — انظر .gitignore)
# يُستخدم من scripts/supabase-db-push.sh لتنفيذ: npx supabase db push
#
# كلمة المرور: Supabase Dashboard → Project Settings → Database → Database password
#
# اتصال مباشر (غالباً IPv6):
# SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.hhajmpjifkhkdkgrtgfc.supabase.co:5432/postgres?sslmode=require
#
# Session pooler (IPv4) — إذا فشل الاتصال المباشر من بيئة بلا IPv6؛ استبدل المنطقة إن لزم (مثلاً eu-west-1):
# اسم المستخدم: postgres.PROJECT_REF
# SUPABASE_DB_URL=postgresql://postgres.hhajmpjifkhkdkgrtgfc:YOUR_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
